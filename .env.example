# AIEventRadar 환경변수 템플릿
# 실제 .env / .env.local 파일은 git에 커밋하지 말 것
# 자세한 발급/설정 가이드: docs/REQUIREMENTS.md

# === 운영 모드 ===
NODE_ENV=development
LOG_LEVEL=info
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Supabase (필수) ===
# https://supabase.com/dashboard/project/[id]/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # 노출 금지: cron/admin 전용

# === 인증 (필수) ===
AUTH_SECRET=                        # 세션 암호화 키 (32자 이상 랜덤 문자열)

# === 이메일: Resend (필수) ===
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@aieventradar.com

# === Cron 보안 (필수) ===
CRON_SECRET=                        # /api/cron/* Bearer 인증 토큰 (32자 이상 랜덤)

# === 소스 어댑터 토글 (선택, 기본 모두 활성) ===
ENABLE_FESTA=true                   # Festa 폐업 위험 시 false로 비활성화
ENABLE_EVENTUS=true
ENABLE_LUMA=true
ENABLE_DEV_EVENT=true
ENABLE_DEVPOST=true

# === 데이터 소스 키 (선택) ===
GITHUB_TOKEN=                       # Dev-Event GitHub API (rate limit 5000/h)

# === 개발/테스트 모드 ===
USE_MOCK=false                      # true 시 모든 어댑터가 mocks/*.json 사용
USE_LLM_CLASSIFY=false              # true 시 OpenAI 보조 분류 (룰베이스 우선)
OPENAI_API_KEY=                     # USE_LLM_CLASSIFY=true일 때만 필요

# === 모니터링: Sentry (선택) ===
# https://sentry.io/settings/[org]/projects/[proj]/keys/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# === Phase 2: 추가 알림 채널 (현재 미사용) ===
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=

# === Phase 2: 결제 (현재 미사용) ===
# TOSS_PAYMENTS_SECRET_KEY=
# TOSS_PAYMENTS_CLIENT_KEY=
